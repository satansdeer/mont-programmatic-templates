{
  "name": "mont-programmatic-templates",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @mont-templates/creator-studio --filter @mont-templates/showcase run dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test && pnpm build && pnpm test:templates",
    "test:templates": "node scripts/validate-templates.mjs",
    "studio:dev": "pnpm --filter @mont-templates/creator-studio dev",
    "showcase:dev": "pnpm --filter @mont-templates/showcase dev",
    "registry:build": "node scripts/build-registry.mjs",
    "netlify:build": "pnpm registry:build && pnpm --filter @mont-templates/showcase build && STUDIO_BASE=/studio/ pnpm --filter @mont-templates/creator-studio build && node scripts/build-netlify-site.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "@usemont/scene-model": "file:vendor/usemont-packages/usemont-scene-model-0.0.0.tgz"
    }
  }
}
